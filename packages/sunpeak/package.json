{
  "name": "sunpeak",
  "version": "0.20.4",
  "description": "Inspector, testing framework, and app framework for MCP Apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./inspector": {
      "import": {
        "types": "./dist/inspector/index.d.ts",
        "default": "./dist/inspector/index.js"
      }
    },
    "./chatgpt": {
      "import": {
        "types": "./dist/chatgpt/index.d.ts",
        "default": "./dist/chatgpt/index.js"
      }
    },
    "./claude": {
      "import": {
        "types": "./dist/claude/index.d.ts",
        "default": "./dist/claude/index.js"
      }
    },
    "./style.css": "./dist/style.css",
    "./mcp": {
      "import": {
        "types": "./dist/mcp/index.d.ts",
        "default": "./dist/mcp/index.js"
      }
    },
    "./host": {
      "import": {
        "types": "./dist/host/index.d.ts",
        "default": "./dist/host/index.js"
      }
    },
    "./host/chatgpt": {
      "import": {
        "types": "./dist/host/chatgpt/index.d.ts",
        "default": "./dist/host/chatgpt/index.js"
      }
    },
    "./test": {
      "import": {
        "types": "./bin/lib/test/test-fixtures.d.mts",
        "default": "./bin/lib/test/test-fixtures.mjs"
      }
    },
    "./test/config": {
      "import": {
        "types": "./bin/lib/test/test-config.d.mts",
        "default": "./bin/lib/test/test-config.mjs"
      }
    },
    "./test/live": {
      "import": {
        "types": "./bin/lib/live/live-fixtures.d.mts",
        "default": "./bin/lib/live/live-fixtures.mjs"
      }
    },
    "./test/live/config": {
      "import": {
        "types": "./bin/lib/live/test-config.d.mts",
        "default": "./bin/lib/live/test-config.mjs"
      }
    },
    "./test/live/chatgpt": {
      "import": {
        "types": "./bin/lib/live/chatgpt-fixtures.d.mts",
        "default": "./bin/lib/live/chatgpt-fixtures.mjs"
      }
    },
    "./test/live/chatgpt/config": {
      "import": {
        "types": "./bin/lib/live/chatgpt-config.d.mts",
        "default": "./bin/lib/live/chatgpt-config.mjs"
      }
    },
    "./test/inspect/config": {
      "import": {
        "types": "./bin/lib/inspect/inspect-config.d.mts",
        "default": "./bin/lib/inspect/inspect-config.mjs"
      }
    },
    "./inspect": {
      "import": {
        "types": "./bin/lib/inspect/inspect-server.d.mts",
        "default": "./bin/lib/inspect/inspect-server.mjs"
      }
    },
    "./eval": {
      "import": {
        "types": "./bin/lib/eval/eval-types.d.mts",
        "default": "./bin/lib/eval/eval-runner.mjs"
      }
    },
    "./eval/plugin": {
      "import": "./bin/lib/eval/eval-vitest-plugin.mjs"
    },
    "./eval/reporter": {
      "import": "./bin/lib/eval/eval-reporter.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "sunpeak": "./bin/sunpeak.js"
  },
  "files": [
    "dist",
    "bin",
    "template",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css",
    "**/chatgpt-host.*",
    "**/claude-host.*"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "pnpm -C template dev",
    "format": "prettier --write --list-different \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "pnpm exec playwright test",
    "generate-examples": "node scripts/generate-examples.mjs",
    "validate": "node scripts/validate.mjs",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "openai-app",
    "chatgpt-apps-sdk",
    "chatgpt-app",
    "mcp-ui",
    "mcp",
    "chatgpt-inspector",
    "claude",
    "claude-inspector",
    "testing",
    "multi-platform",
    "react",
    "tailwind",
    "sunpeak"
  ],
  "author": "Sunpeak AI",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "ai": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "@ai-sdk/openai": "^1.0.0 || ^2.0.0 || ^3.0.0",
    "@ai-sdk/anthropic": "^1.0.0 || ^2.0.0 || ^3.0.0",
    "@ai-sdk/google": "^1.0.0 || ^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "@ai-sdk/openai": {
      "optional": true
    },
    "@ai-sdk/anthropic": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vitejs/plugin-react": "^6.0.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.28.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-plugin-dts": "^4.5.4",
    "@playwright/test": "^1.59.1",
    "vitest": "^4.1.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Sunpeak-AI/sunpeak"
  },
  "bugs": {
    "url": "https://github.com/Sunpeak-AI/sunpeak/issues"
  },
  "homepage": "https://sunpeak.ai/"
}
